# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (User Data)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=taskmanager
PG_USER=postgres
PG_PASSWORD=yourpassword

# MongoDB (Task Data)
MONGO_URI=mongodb://localhost:27017/taskmanager

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# bcrypt
BCRYPT_ROUNDS=12
